# BACKGROUND
background {
    monitor =
    path = ~/Pictures/CurrentWall/current.wall
    blur_passes = 1
    contrast = 0.8916
    brightness = 0.6172
    vibrancy = 0.1696
    vibrancy_darkness = 0.0
}

# GENERAL
general {
    no_fade_in = true
    grace = 0
    disable_loading_bar = false
}

# GREETINGS
label {
    monitor =
    text = I'm Batman
    color = rgba(216, 222, 233, .75)
    font_size = 40
    font_family = Orbitron
    position = 1560, -480
    halign = top
    valign = center
}

# Time
label {
    monitor =
    text = cmd[update:1000] echo "<span>$(date +"%I:%M")</span>"
    color = rgba(216, 222, 233, .75)
    font_size = 48
    font_family = Orbitron
    position = 50, -50
    halign = left
    valign = top
}

# Day-Month-Date
label {
    monitor =
    text = cmd[update:1000] echo -e "$(date +"%A, %B %d")"
    color = rgba(216, 222, 233, .75)
    font_size = 34
    font_family = SpaceMono Nerd Font Bold
    position = 50, -140
    halign = left
    valign = top
}

# Profie-Photo
image {
    monitor =
    path = ~/Pictures/Profile/kogami.png
    border_size = 2
    border_color = rgba(255, 255, 255, .75)
    size = 200
    rounding = -1
    rotate = 0
    reload_time = -1
    reload_cmd =
    position = 0, 100
    halign = center
    valign = center
}

# USER-BOX
#shape {
    monitor =
    size = 320, 55
    color = rgba(255, 255, 255, .1)
    rounding = -1
    border_size = 0
    border_color = rgba(255, 255, 255, 1)
    rotate = 0
    xray = false # if true, make a "hole" in the background (rectangle of specified size, no rotation)

    position = 0, -140
    halign = center
    valign = center
}

# USER
#label {
    monitor =
    text =      $USER
    color = rgba(216, 222, 233, 0.80)
    outline_thickness = 0
    dots_size = 0.2 # Scale of input-field height, 0.2 - 0.8
    dots_spacing = 0.2 # Scale of dots' absolute size, 0.0 - 1.0
    dots_center = true
    font_size = 16
    font_family = SpaceMono Nerd Font Bold
    position = -25, -140
    halign = center
    valign = center
}

# INPUT FIELD
input-field {
    monitor =
    size = 320, 55
    outline_thickness = 0
    dots_size = 0.2 # Scale of input-field height, 0.2 - 0.8
    dots_spacing = 0.2 # Scale of dots' absolute size, 0.0 - 1.0
    dots_center = true
    outer_color = rgba(255, 255, 255, 0)
    inner_color = rgba(255, 255, 255, 0.1)
    font_color = rgb(200, 200, 200)
    fade_on_empty = false
    font_family = JetbrainsMono Nerd Font Bold
    placeholder_text = <i><span foreground="##ffffff99">     Enter Pass     </span></i>
    hide_input = false
    position = 0, -70
    halign = center
    valign = center
}

# CURRENT SONG
label {
    monitor =
    text = cmd[update:1000] echo "$(~/scripts/songdetail.sh)"
    color = rgba(255, 255, 255, 0.65)
    font_size = 12
    font_family = SF Pro Display
    position = 60, 45
    halign = center
    valign = bottom
}
